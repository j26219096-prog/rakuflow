# ── Environment Variables for RakuFlow ────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=rakuflow
POSTGRES_USER=rakuflow
POSTGRES_PASSWORD=changeme_strong_password

# ── Kafka ──────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
MESSAGE_DELAY_SEC=0.1

# ── Data paths ─────────────────────────────────────────────────────────────────
DATA_DIR=./data/raw
RAKUFLOW_HOME=/opt/rakuflow

# ── Spark ──────────────────────────────────────────────────────────────────────
SPARK_KAFKA_JAR=org.apache.spark:spark-sql-kafka-0-10_2.12:3.5.0
SPARK_POSTGRES_JAR=/opt/jars/postgresql-42.7.3.jar

# ── Airflow ────────────────────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=your_fernet_key_here
AIRFLOW_ADMIN_PASSWORD=admin123
AIRFLOW__CORE__EXECUTOR=LocalExecutor

# ── Alerts ─────────────────────────────────────────────────────────────────────
ALERT_EMAIL=your-email@example.com
SMTP_HOST=smtp.gmail.com

# ── Streamlit dashboard ────────────────────────────────────────────────────────
STREAMLIT_HOST=streamlit
STREAMLIT_PORT=8501

# ── Great Expectations ─────────────────────────────────────────────────────────
GE_ROOT_DIR=./great_expectations
